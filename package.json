    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-categories": "tsx scripts/sync-categories-from-filters.ts",
    "db:prune-audit-logs": "tsx scripts/prune-audit-logs.ts",
