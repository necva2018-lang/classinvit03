    "docker:down": "docker compose down",
    "local:db": "docker compose up -d && node scripts/wait-for-postgres.mjs",
    "local:init": "docker compose up -d && node scripts/wait-for-postgres.mjs && npm run db:deploy && npm run db:seed",
    "win:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/win-local-all.ps1"
