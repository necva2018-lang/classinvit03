generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 使用者與權限管理
model User {
  id          String   @id @default(cuid())
  name        String?
  email       String?  @unique
  /// bcrypt 雜湊；OAuth／舊資料可為 null（僅 Email＋密碼登入需有值）
  passwordHash String? @db.Text @map("user_password_hash")
  /// 後台會員管理：停用後不可登入（資料保留，不做硬刪）
  isActive    Boolean  @default(true) @map("is_active")
  image       String?
  role        Role     @default(STUDENT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  enrollments Enrollment[]
  loginLogs   AuthLoginLog[]
  courseViewLogs CourseViewLog[]
  uploadedMedia MediaAsset[] @relation("MediaUploadedBy")
}

enum Role {
  STUDENT
  ADMIN
  INSTRUCTOR
}

enum CourseStatus {
  DRAFT
  PAUSED
}

/// 前台雙按鈕語意：一般電商購物流 vs 補助／諮詢報名
enum CourseCtaKind {
  CART
  SUBSIDY
}

enum AuthLoginStatus {
  SUCCESS
  FAIL
}

enum AuthLoginFailureCode {
  INVALID_INPUT
  USER_NOT_FOUND
  PASSWORD_NOT_SET
  INVALID_PASSWORD
  USER_DISABLED
}

enum MediaKind {
  IMAGE
  PDF
  YOUTUBE
}

enum MediaStatus {
  ACTIVE
  ARCHIVED
}

// 課程分類 (如：人工智慧、網頁前端)
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  /// 排序權重（數字越小越前；導覽與下拉選單依此欄位）
  sortOrder Int      @default(0) @map("category_sort_order")
  courses   Course[]
}

// 課程主體
model Course {
  id              String   @id @default(cuid())
  title           String
  subtitle        String?  @db.Text
  description     String?  @db.Text
  /// 前台「學習前基本能力」：每行一則，空白則顯示站方預設
  prerequisiteText String? @db.Text @map("course_prerequisite_text")
  /// 前台「學習前準備」：每行一則
  preparationText  String? @db.Text @map("course_preparation_text")
  /// 前台「介紹」分頁 · 你可以學到：每行一則，空白則依分類顯示站方預設
  learnOutcomesText String? @db.Text @map("course_learn_outcomes_text")
  /// 前台「介紹」分頁 · 適合對象：每行一則，空白則依分類顯示站方預設
  targetAudienceText String? @db.Text @map("course_target_audience_text")
  /// 前台「介紹」分頁 · 說明區段（圖片／影片／文字區塊 JSON 陣列）
  introBlocksJson    Json?   @map("course_intro_blocks_json")
  /// 前台側欄「課程資訊」· 課程時長（空白則不顯示該列）
  infoDurationText    String? @db.Text @map("course_info_duration_text")
  /// 前台側欄「課程資訊」· 單元結構說明
  infoStructureText   String? @db.Text @map("course_info_structure_text")
  /// 前台側欄「課程資訊」· 學習資源
  infoResourcesText   String? @db.Text @map("course_info_resources_text")
  /// 前台側欄「課程資訊」· 完訓證明
  infoCertificateText String? @db.Text @map("course_info_certificate_text")
  /// 前台 CTA：加入購物車（或自訂）按鈕文字
  ctaCartText     String?  @db.Text @map("course_cta_cart_text")
  /// 前台 CTA：加入購物車（或自訂）按鈕連結
  ctaCartUrl      String?  @db.Text @map("course_cta_cart_url")
  /// 前台 CTA：立即購買（或自訂）按鈕文字
  ctaBuyText      String?  @db.Text @map("course_cta_buy_text")
  /// 前台 CTA：立即購買（或自訂）按鈕連結
  ctaBuyUrl       String?  @db.Text @map("course_cta_buy_url")
  /// 前台雙按鈕類型（購物車／補助課預設文案不同）
  ctaKind         CourseCtaKind @default(CART) @map("course_cta_kind")
  /// 列表卡片：無講師時副行（留空則顯示「線上影音課程」）
  listingNoInstructorLine String? @db.Text @map("course_listing_no_instructor_line")
  /// 列表卡片：尚無評價時說明（留空則顯示站方預設一句）
  listingNoReviewsLine   String? @db.Text @map("course_listing_no_reviews_line")
  /// 後台營運狀態（草稿／暫停）
  status          CourseStatus @default(DRAFT) @map("course_status")
  imageUrl        String?  @db.Text
  price           Float?
  discountedPrice Float?
  isPublished     Boolean  @default(false)

  categories Category[]

  sections       Section[]
  enrollments    Enrollment[]
  announcements  CourseAnnouncement[]
  viewLogs       CourseViewLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 前台「公告」分頁
model CourseAnnouncement {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  body      String?  @db.Text
  sortOrder Int      @default(0) @map("announcement_sort_order")
  createdAt DateTime @default(now())

  @@index([courseId])
}

// 課程章節 (如：第一章：環境架設)
model Section {
  id       String @id @default(cuid())
  title    String
  /// 排序權重（數字越小越前）
  order    Int    @map("section_order")
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

// 課堂內容 (如：1-1 安裝 VS Code)
model Lesson {
  id        String  @id @default(cuid())
  title     String
  videoUrl  String? @db.Text
  duration  Int?
  order     Int     @map("lesson_order")
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

// 首頁輪播 Banner
model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?  @db.Text
  /// 圖片輪播或影片 poster（擇一或併用；與 videoUrl 至少填一）
  imageUrl  String?  @db.Text
  /// 背景影片直連網址（https，建議 .mp4 / .webm）；有值時前台以影片為主
  videoUrl  String?  @db.Text @map("banner_video_url")
  linkUrl   String?  @db.Text
  linkLabel String?
  order     Int      @default(0) @map("banner_order")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 全站鍵值設定（如 site_name、SEO、聯絡資訊）
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// 訂單/購買紀錄
model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

/// 會員登入紀錄（成功/失敗）
model AuthLoginLog {
  id           String               @id @default(cuid())
  userId       String?
  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// 表單輸入 email（失敗時也可追蹤），統一小寫儲存
  emailInput   String?              @map("email_input")
  status       AuthLoginStatus
  failureCode  AuthLoginFailureCode? @map("failure_code")
  ipHash       String?              @map("ip_hash")
  userAgent    String?              @db.Text @map("user_agent")
  createdAt    DateTime             @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

/// 課程詳情頁瀏覽紀錄（含會員與訪客）
model CourseViewLog {
  id         String   @id @default(cuid())
  courseId   String   @map("course_id")
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// 訪客識別 cookie；會員也會帶入，供跨登入前後關聯分析
  visitorId  String?  @map("visitor_id")
  ipHash     String?  @map("ip_hash")
  userAgent  String?  @db.Text @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([courseId, createdAt])
  @@index([userId, createdAt])
  @@index([visitorId, createdAt])
}

/// 媒體主檔：檔案（二進位）直存 PostgreSQL，或 YouTube URL
model MediaAsset {
  id          String      @id @default(cuid())
  kind        MediaKind
  status      MediaStatus @default(ACTIVE)

  originalName String? @map("original_name")
  /// 自訂標籤（用於分類/搜尋）
  tags         String[] @default([])
  mimeType     String? @map("mime_type")
  sizeBytes    Int?    @map("size_bytes")
  sha256       String? @map("sha256")

  /// 檔案內容（IMAGE/PDF）；YouTube 類型為 null
  blobData   Bytes?  @map("blob_data")
  /// YouTube 原始/正規化連結（YOUTUBE）；檔案類型為 null
  youtubeUrl String? @map("youtube_url") @db.Text

  uploadedByUserId String? @map("uploaded_by_user_id")
  uploadedByUser   User?   @relation("MediaUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usages MediaUsage[]

  @@index([kind, createdAt])
  @@index([status, createdAt])
  @@index([uploadedByUserId, createdAt])
  @@index([sha256])
}

/// 一素材多處使用：記錄被哪個實體與欄位引用
model MediaUsage {
  id         String     @id @default(cuid())
  assetId    String     @map("asset_id")
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  entityType String     @map("entity_type")
  entityId   String     @map("entity_id")
  fieldPath  String     @map("field_path")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([entityType, entityId, fieldPath])
  @@index([assetId, createdAt])
  @@index([entityType, entityId])
}
